ANTHROPIC_API_KEY=your_key_here
VOYAGE_API_KEY=your_key_here
USE_RETRIEVAL=true

# D-037: production backend + tenant + retrieval mode.
# Unset MOTHERDUCK_TOKEN -> local dev reads data/northwind.db directly.
# Set MOTHERDUCK_TOKEN    -> reads MotherDuck database "askerp" over the Postgres wire protocol.
MOTHERDUCK_TOKEN=
ACTIVE_TENANT=mro
RETRIEVAL_MODE=dense
